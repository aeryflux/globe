{
  "name": "@aeryflux/globe",
  "version": "0.3.1",
  "description": "Portable 3D globe component for React and React Native (Expo)",
  "author": "martinbaud",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aeryflux/globe.git"
  },
  "keywords": [
    "globe",
    "3d",
    "threejs",
    "react",
    "react-native",
    "expo",
    "webgl",
    "visualization"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./react": {
      "import": "./dist/react/index.js",
      "types": "./dist/react/index.d.ts"
    },
    "./react-native": {
      "import": "./dist/react-native/index.js",
      "types": "./dist/react-native/index.d.ts"
    },
    "./models/*": "./models/*"
  },
  "files": [
    "dist",
    "models"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "three": ">=0.150.0"
  },
  "peerDependenciesMeta": {
    "expo-gl": {
      "optional": true
    },
    "expo-three": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/three": "^0.160.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  }
}
